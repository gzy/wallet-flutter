{
    // 命令面板「Tasks: Run Task」或终端菜单「运行任务…」执行。链/主测网由 `GET /api/app/chains` 等接口决定，不再传 EVM_FLAVOR。
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Android: APK",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: APK 分 ABI",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk --split-per-abi"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: App Bundle",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build appbundle"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        }
    ]
}