{
    // 命令面板「Tasks: Run Task」或终端菜单「运行任务…」执行。链/主测网由 `GET /api/app/chains` 等接口决定，不再传 EVM_FLAVOR。
    // 发版：改 pubspec.yaml 的 `version:` 后，可先跑「Flutter: 版本号同步到 Android/iOS（config-only）」刷新 local.properties / Generated.xcconfig；OTA 清单另跑「OTA: 从 pubspec 同步 deploy/ota」；打包再选 Android / iOS 任务。
    // 首包/Release 可能很久且 Console 里长时间只显示 assembleRelease 一行，属 Flutter 对 Gradle 的包装默认不刷子步骤；要进度请用「APK（详细日志）」或终端里 `cd android && ./gradlew assembleRelease --info`。
    "version": "2.0.0",
    "tasks": [
        {
            "label": "OTA: 从 pubspec 同步 deploy/ota",
            "type": "shell",
            "command": "bash",
            "args": ["-lc", "dart run tools/sync_ota_version.dart"],
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Flutter: 版本号同步到 Android/iOS（config-only）",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "flutter pub get && export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk --config-only && flutter build ios --config-only"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: APK",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: APK（详细日志）",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk -v"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: APK 分 ABI",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build apk --split-per-abi"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "Android: App Bundle",
            "type": "shell",
            "command": "bash",
            "args": [
                "-lc",
                "export JAVA_HOME=\"/Applications/Android Studio.app/Contents/jbr/Contents/Home\"; export PATH=\"$JAVA_HOME/bin:$PATH\"; flutter build appbundle"
            ],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        },
        {
            "label": "iOS: IPA",
            "type": "shell",
            "command": "bash",
            "args": ["-lc", "flutter build ipa"],
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared", "focus": true },
            "problemMatcher": []
        }
    ]
}
